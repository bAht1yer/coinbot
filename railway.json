{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "apps/worker/Dockerfile",
        "watchPatterns": [
            "apps/worker/**",
            "packages/db/**"
        ]
    },
    "deploy": {
        "startCommand": "npm run start:prod",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
    }
}