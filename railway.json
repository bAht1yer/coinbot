{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "coinbot-worker/Dockerfile",
        "watchPatterns": [
            "coinbot-worker/**"
        ]
    },
    "deploy": {
        "startCommand": "npm run start:prod",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
    }
}